## Local CRE workflow simulation (example)
# Copy to `.env` and fill in real values. Never commit `.env`.
#
# This file maps to `secrets.yaml` names and supports:
# - `cre workflow simulate ... --target local-simulation`
# - deployment-ready staging/production targets once Early Access is enabled

# Wallet used by CRE CLI account/owner operations.
CRE_ETH_PRIVATE_KEY=YOUR_PRIVATE_KEY_HEX_WITHOUT_0x

# Secrets mapped in `secrets.yaml`.
KEEPR_API_KEY_VALUE=replace-with-keepr-api-key
KEEPR_API_BASE_URL_VALUE=https://4626.fun/api
KEEPR_PRIVATE_KEY_VALUE=YOUR_KEEPER_PRIVATE_KEY_HEX_WITHOUT_0x

# Optional AI provider keys for the CRE -> API AI assessment path.
GROQ_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
ELIZA_LLM_PROVIDER_PRIORITY=Groq,OpenAI,Anthropic,OpenRouter

